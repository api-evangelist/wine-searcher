                "wine-check"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "api_key",
                  "value": "<string>",
                  "description": "(Required) Your Wine-Searcher API key"
                },
                {
                  "disabled": false,
                  "key": "winename",
                  "value": "<string>",
                  "description": "(Required) Name of the wine to look up (URL-encoded, e.g., haut+brion)"
                },
                {
                  "disabled": false,
                  "key": "vintage",
                  "value": "<string>",
                  "description": "Wine vintage year (4-digit year or 'NV' for non-vintage)"
                },
                {
                  "disabled": false,
                  "key": "currencycode",
                  "value": "USD",
                  "description": "ISO 4217 currency code for price results (default: USD)"
                },
                {
                  "disabled": false,
                  "key": "location",
                  "value": "<string>",
                  "description": "Filter results by country code (e.g., USA, GBR)"
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>",
                  "description": "Filter results by US state code (e.g., CA, NY)"
                },
                {
                  "disabled": false,
                  "key": "offer_type",
                  "value": "<string>",
                  "description": "Filter by offer type (R=retail, A=auction, B=both)"
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "json",
                  "description": "Response format (json or xml, default is xml)"
                }
